# Exemplo de variáveis de ambiente
# Renomeie para .env e preencha conforme necessário

# Anthropic / Claude Code / LM Studio (Opção 1 e 3)
# ANTHROPIC_API_KEY=sua_chave_aqui
# ANTHROPIC_BASE_URL=http://localhost:1234
# Defina o modelo local para o Claude Code 
# CLAUDE_MODEL=gpt-oss:20b

# OpenAI / Codex (Opção 2)
# OPENAI_API_KEY=sua_chave_aqui
# Defina o modelo para o Codex (Padrão: gpt-oss:20b)
# CODEX_MODEL=gpt-oss:20b

# LM Studio
# LM_API_TOKEN=lmstudio

# Hermes Agent (Opção 4)
# Defina o modelo para o Hermes Agent (opcional)
# HERMES_MODEL=gpt-oss:20b
